{
  "name": "vanitylens",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.5.3",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:ci": "jest --runInBand --ci",
    "doctor": "pnpm dlx expo-doctor",
