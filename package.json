    "verify": "pnpm typecheck && pnpm lint && pnpm test:ci && pnpm doctor"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^2.2.0",
    "expo": "^56.0.12",
    "expo-constants": "~56.0.18",
    "expo-image-picker": "^56.0.18",
    "expo-linking": "~56.0.14",
    "expo-router": "^56.2.11",
    "react": "^19.2.3",
    "react-native": "^0.85.3",
    "react-native-safe-area-context": "^5.7.0",
    "react-native-screens": "^4.25.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@google/genai": "^2.9.0",
    "@react-native/jest-preset": "^0.86.0",
    "@testing-library/react-native": "^14.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^29.5.14",
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.17",
    "@types/react-test-renderer": "^19.1.0",
    "babel-preset-expo": "^56.0.15",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "eslint": "^9.39.1",
    "eslint-config-expo": "^56.0.4",
    "express": "^5.2.1",
    "jest": "^29.7.0",
    "jest-expo": "^56.0.5",
    "react-test-renderer": "^19.2.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
