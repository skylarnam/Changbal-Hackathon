{
  "name": "vanitylens",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.5.3",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:ci": "jest --runInBand --ci",
    "doctor": "pnpm dlx expo-doctor",
    "analyzer": "tsx server/index.ts",
    "proxy:install": "cd proxy && npm install",
    "proxy:dev": "cd proxy && npm run dev",
    "proxy:typecheck": "cd proxy && npm run typecheck",
    "proxy:lint": "cd proxy && npm run lint",
    "proxy:test": "cd proxy && npm run test:ci",
    "proxy:verify": "cd proxy && npm run verify",
    "verify": "pnpm typecheck && pnpm lint && pnpm test:ci && pnpm doctor"
  },
  "dependencies": {
    "@expo/metro-runtime": "~6.1.2",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "expo": "^54.0.35",
    "expo-constants": "~18.0.13",
    "expo-image-manipulator": "~14.0.8",
    "expo-image-picker": "^17.0.11",
    "expo-linking": "~8.0.12",
    "expo-router": "^6.0.24",
    "react": "^19.1.0",
    "react-native": "^0.81.5",
    "react-native-safe-area-context": "^5.6.2",
    "react-native-screens": "^4.16.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@expo/ngrok": "^4.1.3",
    "@google/genai": "^2.9.0",
    "@react-native/jest-preset": "^0.86.0",
    "@testing-library/react-native": "^14.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^29.5.14",
    "@types/node": "^26.0.0",
    "@types/react": "^19.1.17",
    "@types/react-test-renderer": "^19.1.0",
    "babel-preset-expo": "^54.0.11",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "eslint": "^9.39.1",
    "eslint-config-expo": "^10.0.0",
    "express": "^5.2.1",
    "jest": "^29.7.0",
    "jest-expo": "^54.0.17",
    "react-test-renderer": "^19.2.3",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3"
  }
}
